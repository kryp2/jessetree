# jessetree environment variables

# --- Data source selection ---
# Values: "postgres" (direct DB) | "peck-reader" (HTTP API)
JESSETREE_DATA_SOURCE=postgres

# --- Postgres (when JESSETREE_DATA_SOURCE=postgres) ---
# Pointing at peck_db either locally via Cloud SQL proxy or remote.
# Using Cloud SQL proxy on localhost:5433 is the default peck-to dev setup.
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=peck_user
PGPASSWORD=
PGDATABASE=peck_db
PGSSLMODE=disable

# --- peck-reader HTTP API (when JESSETREE_DATA_SOURCE=peck-reader) ---
PECK_READER_URL=https://reader.peck.to

# --- App ---
PORT=3000
PUBLIC_SITE_URL=https://jessetree.xyz
PUBLIC_WOC_URL=https://whatsonchain.com/tx
